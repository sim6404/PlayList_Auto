# ============================================================
#  Velvet Radio — .gitignore
# ============================================================

# 환경변수 (절대 커밋 금지)
.env
config/.env
*.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# 가상환경
venv/
.venv/
env/
ENV/

# 생성 데이터 (대용량, 개인 데이터)
velvet-radio/data/audio/
velvet-radio/data/videos/
velvet-radio/data/images/
velvet-radio/data/exports/
velvet-radio/data/pending_approval/
velvet-radio/data/approved/
velvet-radio/logs/

# 단, data 디렉토리 구조는 유지
!velvet-radio/data/.gitkeep
!velvet-radio/data/playlists/.gitkeep
!velvet-radio/data/lyrics/.gitkeep
!velvet-radio/logs/.gitkeep

# Google OAuth 자격증명
config/gdrive_credentials.json
config/token.json
*.json.key

# n8n 데이터
velvet-radio/n8n/data/

# Docker 볼륨
n8n_data/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# 테스트 아티팩트
*.mp3
*.mp4
*.jpg
*.jpeg
*.png
*.srt

# Vercel
.vercel/
