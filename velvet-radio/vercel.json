{
  "version": 2,
  "builds": [
    {
      "src": "dashboard/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dashboard/app.py"
    }
  ],
  "env": {
    "DATA_DIR": "/tmp/data",
    "LOG_DIR": "/tmp/logs",
    "VERCEL": "1"
  },
  "regions": ["icn1"]
}
