# ============================================================
#  Velvet Radio — Environment Variables Template
#  복사 후 .env 로 저장하고 실제 값을 입력하세요.
# ============================================================

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Suno API (서드파티) ---
SUNO_API_KEY=your_suno_api_key_here
SUNO_API_BASE_URL=https://api.sunoapi.org/v1
SUNO_MODEL=v5

# --- Image Generation (Flux / Apiframe) ---
IMAGE_API_KEY=your_image_api_key_here
IMAGE_API_URL=https://api.apiframe.ai/v1
IMAGE_MODEL=flux-pro

# --- YouTube Data API v3 ---
YOUTUBE_CLIENT_ID=your_youtube_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token
YOUTUBE_CHANNEL_ID=UC1_f-igasDLBcV3VyxYRfAA

# --- Google Drive ---
GDRIVE_CREDENTIALS_PATH=./config/gdrive_credentials.json
GDRIVE_FOLDER_ID=your_google_drive_folder_id

# --- Telegram Bot (알림 + 승인) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_ADMIN_IDS=123456789,987654321

# --- n8n ---
N8N_PASSWORD=your_n8n_admin_password
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook

# --- Dashboard (마스터 승인 UI) ---
DASHBOARD_SECRET_KEY=your_super_secret_key_for_flask_sessions
DASHBOARD_PORT=8080
DASHBOARD_HOST=0.0.0.0
MASTER_PASSWORD=your_master_approval_password

# --- 경로 설정 ---
DATA_DIR=./data
CONFIG_DIR=./config
LOG_DIR=./logs

# --- 업로드 설정 ---
UPLOAD_PRIVACY_DEFAULT=private
UPLOAD_SCHEDULE_DELAY_HOURS=2
MAX_CONCURRENT_SUNO_JOBS=3
MAX_RETRY_ATTEMPTS=3

# --- 품질 게이트 ---
MIN_TRACKS_FOR_PUBLISH=15
MIN_DURATION_SECONDS=150
MAX_DURATION_SECONDS=270
TARGET_LUFS_MIN=-14
TARGET_LUFS_MAX=-10
